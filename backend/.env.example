# ========================================
# FleetMaster Backend — Environment Config
# ========================================
# Copy this file to .env and fill in your values.

# Server
PORT=5000

# MongoDB Atlas Connection
MONGODB_URI=

# JWT Authentication
JWT_SECRET=

# Frontend URL (for CORS and password reset links)
FRONTEND_URL=http://localhost:5173

# Cloudinary (Document Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Service (Resend — HTTP API, works on Render Free Tier)
RESEND_API_KEY=
RESEND_FROM_EMAIL=FleetMaster <onboarding@resend.dev>

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
